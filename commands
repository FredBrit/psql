### Войти в postgres
sudo su - postgres -c 'psql mi'

### Insert из sql файла сразу в нужную схему, в нужную таблицу
\i /tmp/tv_mobile_phone_202512160923.sql

### Вставка из csv файла в конкретную схему, конкретную таблицу
\copy custom.dm_turnover_hour_delta FROM '/tmp/dm_turnover_hour_delta_202512151753.csv' WITH CSV HEADER VERBOSE

### Снятие дампа
pg_dump -h localhost -U fbritanov -d mi \
  --table=custom.dm_turnover_hour_delta \
  --column-inserts \
  --no-owner --no-privileges \
  --encoding=UTF8 \
  -f /tmp/dm_turnover_hour_delta.sql

